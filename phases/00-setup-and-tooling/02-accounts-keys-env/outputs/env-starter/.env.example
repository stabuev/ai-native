# Контракт ключей окружения. Скопируй в .env и впиши реальные значения.
# .env держи в .gitignore — он НЕ коммитится.

ANTHROPIC_API_KEY=your-key-here   # консоль Anthropic, формат sk-ant-...
OPENAI_API_KEY=your-key-here      # OpenAI Platform, формат sk-...
GOOGLE_API_KEY=your-key-here      # Google AI Studio
